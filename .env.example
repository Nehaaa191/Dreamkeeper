# 🌙 Dreamkeeper - Environment Variables Template

# 1. Database Configuration
# PostgreSQL Connection URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dreamkeeper?schema=public"

# 2. Authentication
# NextAuth / JWT secret
NEXTAUTH_SECRET="your_nextauth_jwt_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (For V2 social sign-in)
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# 3. AI Services & APIs
# OpenAI API Key for GPT-4o mini
OPENAI_API_KEY="your_openai_api_key_here"

# Anthropic API Key (Alternative for Claude)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Hugging Face API Token (For local inference / Hugging Face space inference APIs)
HUGGINGFACE_API_TOKEN="your_huggingface_token_here"

# 4. Redis Cache & Queue
# Redis connection URL (used by Express API for cache and BullMQ for queue tasks)
REDIS_URL="redis://127.0.0.1:6379"

# 5. Media & Storage CDN
# Cloudinary credentials for storing AI-generated dream scenes
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name_here"
CLOUDINARY_API_KEY="your_cloudinary_api_key_here"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret_here"

# 6. Microservices Ports
PORT=5000
AI_SERVICE_URL="http://localhost:8000"
